# ╔══════════════════════════════════════════════════════════════════════╗
# ║  FrontendGestionPedidos — Variables de entorno (PLANTILLA)          ║
# ║  Copia este archivo a ".env" y completa los valores.               ║
# ║  NUNCA subas tu archivo .env al repositorio.                       ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Backend / API Target ───────────────────────────────────────────
# URL completa del backend (usada por el proxy del dev-server)
API_TARGET=https://localhost:7140

# ─── Rutas base de la API ──────────────────────────────────────────
API_BASE=/api
# CATALOGOS_API_BASE=/api/Catalogos
# CATALOGO_API_BASE=/api/catalogo

# ─── Seguridad ──────────────────────────────────────────────────────
DEFAULT_TIPO_USUARIO=Empleado
# SESSION_TIMEOUT_MINUTES=30
PROXY_SECURE=false
